{
  // Palace (AWS FEM, frequency domain) — X-band inset-fed patch S11.
  // Third-solver arbiter for the rfx (FDTD) vs openEMS (FDTD) dip
  // disagreement (rfx ~10.1 GHz vs openEMS ~9.26 GHz, both ~ -12 dB).
  // Geometry + attributes generated by mesh_patch.py.
  "Problem":
  {
    "Type": "Driven",
    "Verbose": 2,
    "Output": "postpro/patch_s11"
  },
  "Model":
  {
    "Mesh": "palace_patch.msh",
    "L0": 1.0e-3  // mesh coordinates are in mm
  },
  "Domains":
  {
    "Materials":
    [
      {
        // attribute 1 = substrate_vol (RO4003C)
        "Attributes": [1],
        "Permeability": 1.0,
        "Permittivity": 3.38,
        "LossTan": 1.0e-3
      },
      {
        // attribute 2 = air_vol (radiation box)
        "Attributes": [2],
        "Permeability": 1.0,
        "Permittivity": 1.0,
        "LossTan": 0.0
      }
    ]
  },
  "Boundaries":
  {
    "PEC":
    {
      // 3 = ground plane, 4 = patch + feed + flanks (zero-thickness metal)
      "Attributes": [3, 4]
    },
    "Absorbing":
    {
      // 6 = radiation-box outer faces (first-order absorbing = far-field)
      "Attributes": [6],
      "Order": 1
    },
    "LumpedPort":
    [
      {
        // 5 = vertical rectangle at the feed far end, ground -> strip
        "Index": 1,
        "R": 50.0,          // ohm
        "Excitation": true,
        "Attributes": [5],
        "Direction": "+Z"   // strip sits above the ground plane
      }
    ],
    "Postprocessing":
    {
      "FarField":
      {
        "Attributes": [6],
        "NSample": 100,
        "ThetaPhis": [[0.0, 0.0], [90.0, 0.0], [90.0, 90.0]]
      }
    }
  },
  "Solver":
  {
    "Order": 2,
    "Device": "CPU",
    "Driven":
    {
      "Samples":
      [
        {
          "Type": "Linear",
          "MinFreq": 8.0,    // GHz
          "MaxFreq": 12.0,   // GHz
          "FreqStep": 0.05,  // GHz -> 81 points
          "SaveStep": 40     // dump fields every 40 steps (~10 GHz region)
        }
      ]
    },
    "Linear":
    {
      "Type": "Default",
      "KSPType": "GMRES",
      "Tol": 1.0e-8,
      "MaxIts": 200
    }
  }
}
