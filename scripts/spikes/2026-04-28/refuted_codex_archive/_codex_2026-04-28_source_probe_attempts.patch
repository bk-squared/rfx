+def _continuous_source_mode_profiles(
+    a: float,
+    b: float,
+    m: int,
+    n: int,
+    mode_type: str,
+    u_widths: np.ndarray,
+    v_widths: np.ndarray,
+    *,
+    aperture_dA: np.ndarray | None = None,
+    h_offset: tuple[float, float] = (0.5, 0.5),
+) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
+    """Continuous-coordinate analytic templates for soft-current drive.
+
+    The existing ``mode_profile="analytic"`` path samples an analytic mode on
+    rfx's cell-centred template grid and then uses that same template for
+    source and extractor.  Candidate #1 needs a source-only OpenEMS-style
+    weight: evaluate analytic functions over the *physical* aperture box.
+
+    The uniform rfx grid is allowed to fencepost/ceil past the requested
+    WR-90 dimensions.  OpenEMS' symbolic ``SetWeightFunction(E_func)`` is
+    defined in continuous coordinates over the requested aperture, so this
+    helper clips every Yee face cell to ``[0, a] × [0, b]`` and uses small
+    Gauss-Legendre quadrature to compute source-cell averages.  Cells fully
+    outside the physical aperture get zero drive instead of reusing the
+    receive-side DROP weighting kludge.
+    """
+    del aperture_dA  # Source-side normalization uses physical clipped areas.
+    u_widths = np.asarray(u_widths, dtype=np.float64)
+    v_widths = np.asarray(v_widths, dtype=np.float64)
+    nu = int(len(u_widths))
+    nv = int(len(v_widths))
+
+    def _edges(widths: np.ndarray) -> np.ndarray:
+        return np.concatenate(([0.0], np.cumsum(widths, dtype=np.float64)))
+
+    u_edges = _edges(u_widths)
+    v_edges = _edges(v_widths)
+
+    # Four-point tensor-product quadrature is enough for the trigonometric
+    # TE/TM weights here and keeps init cost negligible.
+    q_xi, q_w = np.polynomial.legendre.leggauss(4)
+    q_t = 0.5 * (q_xi + 1.0)
+    q_w = 0.5 * q_w
+
+    def _cell_average(func, *, offset: tuple[float, float]) -> tuple[np.ndarray, np.ndarray]:
+        out = np.zeros((nu, nv), dtype=np.float64)
+        dA = np.zeros((nu, nv), dtype=np.float64)
+        for i in range(nu):
+            u0 = u_edges[i] + float(offset[0]) * u_widths[i]
+            u1 = u_edges[i + 1] + float(offset[0]) * u_widths[i]
+            uc0 = max(0.0, u0)
+            uc1 = min(float(a), u1)
+            if uc1 <= uc0:
+                continue
+            uq = uc0 + q_t * (uc1 - uc0)
+            for j in range(nv):
+                v0 = v_edges[j] + float(offset[1]) * v_widths[j]
+                v1 = v_edges[j + 1] + float(offset[1]) * v_widths[j]
+                vc0 = max(0.0, v0)
+                vc1 = min(float(b), v1)
+                if vc1 <= vc0:
+                    continue
+                vq = vc0 + q_t * (vc1 - vc0)
+                Y, Z = np.meshgrid(uq, vq, indexing="ij")
+                W = q_w[:, None] * q_w[None, :]
+                out[i, j] = float(np.sum(func(Y, Z) * W))
+                dA[i, j] = (uc1 - uc0) * (vc1 - vc0)
+        return out, dA
+
+    if mode_type == "TE":
+        def ey_func(Y, Z):
+            if n <= 0:
+                return np.zeros_like(Y)
+            return -(n * np.pi / b) * np.cos(m * np.pi * Y / a) * np.sin(n * np.pi * Z / b)
+
+        def ez_func(Y, Z):
+            if m <= 0:
+                return np.zeros_like(Y)
+            return (m * np.pi / a) * np.sin(m * np.pi * Y / a) * np.cos(n * np.pi * Z / b)
+
+        def hy_func(Y, Z):
+            if m <= 0:
+                return np.zeros_like(Y)
+            return -(m * np.pi / a) * np.sin(m * np.pi * Y / a) * np.cos(n * np.pi * Z / b)
+
+        def hz_func(Y, Z):
+            if n <= 0:
+                return np.zeros_like(Y)
+            return -(n * np.pi / b) * np.cos(m * np.pi * Y / a) * np.sin(n * np.pi * Z / b)
+
+    elif mode_type == "TM":
+        if m < 1 or n < 1:
+            raise ValueError(f"TM modes require m >= 1 and n >= 1, got ({m}, {n})")
+
+        def ey_func(Y, Z):
+            return (m * np.pi / a) * np.cos(m * np.pi * Y / a) * np.sin(n * np.pi * Z / b)
+
+        def ez_func(Y, Z):
+            return (n * np.pi / b) * np.sin(m * np.pi * Y / a) * np.cos(n * np.pi * Z / b)
+
+        def hy_func(Y, Z):
